{
  "name": "arete_watch_view",
  "description": "Watch any Arete view (list/state), filter and sort stream updates, and return matching entities.",
  "schema": {
    "type": "object",
    "properties": {
      "view": {
        "type": "string",
        "description": "Arete view name to watch."
      },
      "mode": {
        "type": "string",
        "enum": ["list", "state"],
        "default": "list"
      },
      "key": {
        "type": "string",
        "description": "Required for state mode to identify the specific key."
      },
      "ws_url": {
        "type": "string",
        "format": "uri",
        "description": "Optional Arete websocket URL override."
      },
      "stack_name": {
        "type": "string",
        "description": "Optional Arete stack override."
      },
      "filters": {
        "type": "object",
        "additionalProperties": {
          "type": "string"
        }
      },
      "take": {
        "type": "integer",
        "minimum": 1,
        "maximum": 500,
        "default": 50
      },
      "stream_seconds": {
        "type": "integer",
        "minimum": 1,
        "maximum": 300,
        "default": 30
      },
      "where_field": {
        "type": "string"
      },
      "where_op": {
        "type": "string",
        "enum": ["eq", "neq", "gt", "gte", "lt", "lte", "contains"]
      },
      "where_value": {
        "oneOf": [
          { "type": "string" },
          { "type": "number" },
          { "type": "boolean" }
        ]
      },
      "sort_by": {
        "type": "string"
      },
      "sort_order": {
        "type": "string",
        "enum": ["asc", "desc"],
        "default": "desc"
      },
      "select_fields": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "required": ["view"]
  },
  "examples": [
    {
      "view": "pools",
      "mode": "list",
      "take": 25,
      "stream_seconds": 30,
      "sort_by": "tvlUsd",
      "sort_order": "desc"
    },
    {
      "view": "prices",
      "where_field": "symbol",
      "where_op": "eq",
      "where_value": "SOL",
      "stream_seconds": 15
    }
  ]
}
