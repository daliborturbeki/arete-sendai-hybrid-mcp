# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED FOR EVERYTHING (server will not start without these)
# ─────────────────────────────────────────────────────────────────────────────

# Solana RPC endpoint. Required even for read-only use because solana-agent-kit
# initializes a wallet at startup.
RPC_URL=https://api.mainnet-beta.solana.com

# Solana wallet private key. Required even for read-only use (same reason above).
# Use a low-value or dedicated wallet — never your main wallet.
# Format: base58 string  OR  JSON byte array, e.g. [12,34,56,...]
SOLANA_PRIVATE_KEY=your-base58-or-json-array-private-key

# ─────────────────────────────────────────────────────────────────────────────
# ARETE CONNECTION
# ─────────────────────────────────────────────────────────────────────────────

# WebSocket URL of the Arete stack you want to watch.
# Default below connects to the public Ore stack — no API key needed.
ARETE_WS_URL=wss://ore.stack.arete.run

# Stack name (used for view routing within the stack).
ARETE_STACK_NAME=ore

# Arete API key. Required for all stacks.
# Get yours at: https://arete.run/dashboard
ARETE_API_KEY=a4_ak_xxx

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — TUNE BEHAVIOR
# ─────────────────────────────────────────────────────────────────────────────

# Comma-separated list of SendAI action names to expose.
# If empty, a safe default set (trade, fetchprice, stake, lend, balance, wallet)
# is selected automatically. Set to a short list to minimize attack surface.
# SEND_AI_ACTION_ALLOWLIST=trade,fetchprice,getWalletAddress

# URL where Arete skill metadata JSON files are fetched from.
# Change only if you host your own metadata fork.
# SKILLS_REPO_RAW_BASE_URL=https://raw.githubusercontent.com/AreteA4/skills/main

# How long fetched skill metadata is cached (milliseconds). Default: 5 minutes.
# SKILLS_CACHE_TTL_MS=300000

# MCP server identity (shown in Cursor MCP panel).
# MCP_SERVER_NAME=arete-sendai-hybrid
# MCP_SERVER_VERSION=0.1.0

# Log verbosity: debug | info | warn | error
LOG_LEVEL=info
